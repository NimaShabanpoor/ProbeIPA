generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum AbsenceStatus {
  PRESENT
  ABSENT
  EXCUSED
  LATE
  CLOSED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      Role
  createdAt DateTime @default(now())

  classes          Class[]        @relation("TeacherClasses")
  classMemberships ClassStudent[]
  absences         Absence[]
}

model Class {
  id        String   @id @default(cuid())
  name      String
  teacherId String
  teacher   User     @relation("TeacherClasses", fields: [teacherId], references: [id], onDelete: Cascade)
  students  ClassStudent[]
  absences  Absence[]
  createdAt DateTime @default(now())
}

model ClassStudent {
  id        String @id @default(cuid())
  classId   String
  studentId String
  class     Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId])
}

model Absence {
  id        String        @id @default(cuid())
  date      DateTime
  status    AbsenceStatus
  note      String?
  classId   String
  studentId String
  class     Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  student   User          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@unique([classId, studentId, date])
}
